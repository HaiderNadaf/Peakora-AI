{
  "expo": {
    "name": "Peakora AI",
    "slug": "peakora-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",

    "icon": "./assets/icon.png",

    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#171717"
    },
    "assetBundlePatterns": ["**/*"],

    "ios": {
      "supportsTablet": true
    },

    "android": {
      "package": "com.haidernadaf.peakoraai",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#000000"
      }
    },

    "web": {
      "bundler": "metro"
    },

    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "packagingOptions": {
              "pickFirsts": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF",
                "META-INF/*"
              ]
            }
          }
        }
      ],
      "expo-secure-store"
    ],

    "extra": {
      "eas": {
        "projectId": "164d3e90-9ec5-4db7-84b0-9a9fb0fab09d"
      }
    }
  }
}